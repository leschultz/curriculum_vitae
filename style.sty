% Original Author: Timmy Chan
% Edited: Lane E. Schultz

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{resumestyle}

\RequirePackage[
                margin=0.7in,
                top=0.75in,
                ]{geometry}

\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}

\RequirePackage[
                default,
                semibold
                ]{sourcesanspro}

\RequirePackage[
                maxcitenames=99,
                ]{biblatex}

\RequirePackage[nostruts]{titlesec}
\RequirePackage[12pt]{moresize}

\RequirePackage{tabularx}
\RequirePackage{lastpage}
\RequirePackage{ragged2e}
\RequirePackage{csquotes}
\RequirePackage{hyperref}
\RequirePackage{fancyhdr}
\RequirePackage{enumitem}
\RequirePackage{xcolor}
\RequirePackage{array}

\tolerance=1
\emergencystretch=\maxdimen
\hyphenpenalty=10000
\exhyphenpenalty=10000

\setlist[itemize]{itemsep=3pt,topsep=4pt}

\definecolor{highlight}{RGB}{61, 90, 128}

\hypersetup{colorlinks=true,urlcolor=highlight}

\titlespacing*{\section}{0em}{0.75em}{0.75em}
\titleformat{\section}
  {\color{highlight}\raggedright\large}{}{0em}{}[\vspace{-0.75em}\hrulefill]
